<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.CommentsMapper">
    <select id="selectCommentsAll" resultType="com.example.pojo.Comments" parameterType="int">
        select *
        from `comments`
        where `essay_id` = #{essay_id}
        order by `comments_addtime`
        desc;
    </select>
    <insert id="addComments" parameterType="com.example.pojo.Comments">
        insert into `comments`(`essay_id`,`user_name`,`comments_contents`,`comments_addtime`)
        values(#{essay_id},#{user_name},#{comments_contents},#{comments_addtime});
    </insert>
    <delete id="deleteCommentsById" parameterType="int">
        delete from `comments`
        where `comments_id` = #{comments_id};
    </delete>
</mapper>
