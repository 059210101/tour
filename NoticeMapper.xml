<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.NoticeMapper">
    <select id="selectNoticeAll" resultType="com.example.pojo.Notice">
        select *
        from notice
    </select>
    <select id="selectNoticeByTitle" resultType="com.example.pojo.Notice" parameterType="java.lang.String">
        select *
        from notice
        where notice_title like CONCAT('%', #{notice_title}, '%')
    </select>
    <select id="selectNoticeByScenicName" resultType="com.example.pojo.Notice" parameterType="java.lang.String">
        select *
        from notice
        where scenic_name=#{scenic_name}
    </select>
    <select id="selectNoticeById" resultType="com.example.pojo.Notice" parameterType="int">
        select *
        from notice
        where notice_id=#{notice_id}
    </select>

    <insert id="addNotice" parameterType="com.example.pojo.Notice">
        insert into notice(scenic_name,notice_title,notice_image,notice_contents,notice_addtime)
        values(#{scenic_name},#{notice_title},#{notice_image},#{notice_contents},#{notice_addtime})
    </insert>

    <delete id="deleteNotice" parameterType="int">
        delete from notice
        where notice_id=#{notice_id}
    </delete>

    <update id="updateNotice" parameterType="com.example.pojo.Notice">
        update notice
        set scenic_name=#{scenic_name},notice_title=#{notice_title},notice_image=#{notice_image},notice_contents=#{notice_contents},notice_addtime=#{notice_addtime}
        where notice_id=#{notice_id}
    </update>

</mapper>
