<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.UserMapper">
    <insert id="addUser" parameterType="com.example.pojo.Users">
        insert into users (user_name, password, sex, birthday, phone, adddata)
        values (#{user_name}, #{password}, #{sex}, #{birthday}, #{phone}, #{adddata});
    </insert>
    <select id="selectUserAll" resultType="com.example.pojo.Users">
        select *
        from users;
    </select>
    <select id="selectUserByName" resultType="com.example.pojo.Users">
        select *
        from users
        where user_name=#{user_name};
    </select>
    <select id="selectUserById" resultType="com.example.pojo.Users">
        select *
        from users
        where user_id=#{user_id};
    </select>
    <update id="updateUser" parameterType="com.example.pojo.Users">
        update users
        set sex = #{sex},birthday = #{birthday},sex = #{sex},phone = #{phone}
        where user_id = #{user_id};
    </update>
    <update id="updateUserAll">
        update users
        set `password` = #{password}, sex = #{sex},birthday = #{birthday},phone = #{phone}
        where user_id = #{user_id};
    </update>
    <delete id="deleteUser" parameterType="int">
        delete
        from users
        where user_id = #{user_id};
    </delete>

</mapper>
