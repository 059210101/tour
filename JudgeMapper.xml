<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.JudgeMapper">

    <select id="judgeAdmin" resultType="com.example.pojo.Admin">
        select *
        from `admin`
        where admin_name=#{name} and `password`=#{password};
    </select>
    <select id="judgeUsers" resultType="com.example.pojo.Users">
        select *
        from `users`
        where user_name=#{name} and `password`=#{password};
    </select>
</mapper>
